@model IEnumerable<RegionDTO>

<h1 class="mt-3">Regions</h1>

<div class="d-flex justify-content-end mb-3">
    <a 
        class="btn btn-dark" 
        asp-controller="Regions"
        asp-action="Create"
    >New Region</a>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Code</th>
            <th>Name</th>
            <th>Image</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var region in Model)
        {
        <tr>
            <td>@region.Id</td>
            <td>@region.Code</td>
            <td>@region.Name</td>
                <td>@region.RegionImageUrl</td>
        </tr>            
        }
    </tbody>
</table>