@model IEnumerable<RegionDTO>

<h1 class="mt-3">Regions</h1>

@* @if (ViewBag.Response is not null)
{
    <p>@ViewBag.Response</p>
} *@

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Code</th>
            <th>Name</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var region in Model)
        {
        <tr>
            <td>@region.Id</td>
            <td>@region.Code</td>
            <td>@region.Name</td>
        </tr>            
        }
    </tbody>
</table>