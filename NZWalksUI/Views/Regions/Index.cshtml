@model IEnumerable<RegionDTO>

<h1 class="mt-3">Regions</h1>

<div class="d-flex justify-content-end mb-3">
    <a class="btn btn-dark"
       asp-controller="Regions"
       asp-action="Create">New Region</a>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Code</th>
            <th>Name</th>
            <th>Image</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var region in Model)
        {
            <tr>
                <td>@region.Id</td>
                <td>@region.Code</td>
                <td>@region.Name</td>
                <td>@region.RegionImageUrl</td>
                <td class="d-flex flex-row">
                    <a class="btn btn-dark"
                           asp-controller="Regions"
                           asp-action="Update"
                           asp-route-id="@region.Id">
                        Edit
                    </a>
                   @*  <button class="btn btn-danger"
                            type="submit"
                           @*  asp-controller="Regions"
                            asp-action="Delete" 
                          >
                        Delete                                            
                </button>
                   *@
                
            </td>
        </tr>
    }
</tbody>
</table>